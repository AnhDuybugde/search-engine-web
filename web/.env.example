# ===== LLM (Groq) =====
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.1-8b-instant

# ===== Retrieval Mode: bm25 | paper | sgaf =====
# paper = Hybrid SciNCL + BM25 then cross-encoder (replaces Adaptive)
# Paste these on Vercel → Settings → Environment Variables (Production + Preview)
RETRIEVAL_MODE=paper

# ===== Embedding (generalist / TEI / OpenAI-compatible) =====
# Hugging Face: set EMBEDDING_PROVIDER=huggingface + EMBEDDING_API_KEY=hf_...
EMBEDDING_PROVIDER=huggingface
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# EMBEDDING_API_URL=   # required for tei/openai only

# ===== Paper mode: SciNCL dense + cross-encoder (query ↔ document) =====
# Upload indexes with SciNCL (stored in chunks.embedding_json); ask embeds query only.
# Required for full Paper quality on Vercel (HF token above is enough if models public)
SCINCL_EMBEDDING_MODEL=malteos/scincl
# SCINCL_EMBEDDING_API_URL=
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANK_API_KEY=      # optional; defaults to EMBEDDING_API_KEY
# RERANK_API_URL=      # optional dedicated rerank endpoint



# ===== SGAF: Specialist model (B5+P3) =====
# Optional — set to use SGAF mode. Falls back to paper hybrid if not set.
# Specialist model (fine-tuned BGE-small for SciFact)
SPECIALIST_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Threshold for B5 batch shift (default 2.0, frozen from SEG paper)
SGAF_SHIFT_THRESHOLD=2.0
# P3 smoothing window size (default 20)
P3_WINDOW=20
# P3 specialist prior weight (default 0.10)
P3_ALPHA=0.10

# ===== Search =====
TAVILY_API_KEY=
BRAVE_API_KEY=

# ===== Database (Supabase Postgres) =====
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ===== Auth =====
APP_PASSWORD=
APP_SESSION_SECRET=
