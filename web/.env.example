# === LLM (required for answers) ===
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.1-8b-instant

# === Web search (required for /search) ===
TAVILY_API_KEY=
# BRAVE_API_KEY=

# === Retrieval ===
# bm25 | rrf  (adaptive_rrf is a legacy alias for classic equal-weight RRF)
RETRIEVAL_MODE=bm25
# openai | huggingface | tei
EMBEDDING_PROVIDER=tei
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# === Durable DB (required on Vercel / production) ===
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SECRET_KEY=
SUPABASE_PUBLIC_KEY=
# Optional SQL fallback (prefer pooler :6543). Local docker example:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/search
DATABASE_URL=
# Set to 1 only if you intentionally want ephemeral memory DB in production
# ALLOW_MEMORY_DB=0

# === Auth (multi-user) ===
# Users register/login with email+password (stored as scrypt hash in `users` table).
# Session cookie: app_session (HMAC). Set a strong secret in production.
APP_SESSION_SECRET=
# Optional: shared bearer password still accepted for ops/health tools only
APP_PASSWORD=
# Optional separate secret for detailed health diagnostics (falls back to APP_PASSWORD)
HEALTH_SECRET=
# Escape hatch for tests only — never enable in production
# AUTH_DISABLED=0

