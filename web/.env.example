# ===== LLM (Groq) =====
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.1-8b-instant
# Comma-separated server-approved models for per-request generation switching.
LLM_MODELS=llama-3.1-8b-instant
# Optional additional provider/model. The default 8B model remains active.
VILAO_BASE_URL=https://api.vilao.ai/v1
VILAO_API_KEY=replace-with-your-vilao-key
VILAO_MODEL=MiniMax-M2.7

# ===== Retrieval Mode: bm25 | adaptive_rrf | sgaf | legacy_rrf_ce =====
RETRIEVAL_MODE=adaptive_rrf

# ===== Embedding (generalist) =====
EMBEDDING_PROVIDER=huggingface
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# ===== Legacy BM25 + SciNCL + classic RRF + Cross-Encoder =====
# SciNCL is intentionally separate from EMBEDDING_MODEL so existing indexes stay valid.
LEGACY_DENSE_MODEL=malteos/scincl
LEGACY_RRF_K=60
# Optional internal reranker endpoint. Without it, legacy mode returns classic RRF results.
LEGACY_RERANKER_URL=
LEGACY_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ===== SGAF: Specialist model (B5+P3) =====
# Optional — set to use SGAF mode. Falls back to adaptive_rrf if not set.
# Specialist model (fine-tuned BGE-small for SciFact)
SPECIALIST_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Threshold for B5 batch shift (default 2.0, frozen from SEG paper)
SGAF_SHIFT_THRESHOLD=2.0
# P3 smoothing window size (default 20)
P3_WINDOW=20
# P3 specialist prior weight (default 0.10)
P3_ALPHA=0.10

# ===== Search =====
TAVILY_API_KEY=
BRAVE_API_KEY=

# ===== Database (Supabase Postgres) =====
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ===== Auth =====
# Temporary guest mode. Set to 0 to require login again.
AUTH_DISABLED=1
APP_PASSWORD=
APP_SESSION_SECRET=
