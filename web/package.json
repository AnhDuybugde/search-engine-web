{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "test": "vitest run",
    "db:init": "node scripts/db-init.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:beir": "node scripts/seed-beir-raw.mjs --all --max-docs 400 --replace",
    "seed:scifact": "node scripts/seed-beir-raw.mjs --dataset scifact --max-docs 400 --replace",
    "seed:scidocs": "node scripts/seed-beir-raw.mjs --dataset scidocs --max-docs 250 --replace",
    "index:embeddings": "npx tsx scripts/index-embeddings.ts --all-raw-demos",
    "bench:retrieval": "npx tsx scripts/bench-retrieval.ts --title \"SCIFACT (raw)\" --queries 3"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.15",
    "@supabase/supabase-js": "^2.110.7",
    "ai": "^7.0.29",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "unpdf": "^1.6.2",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "esbuild@0.18.20": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
